{
  "manifest_version": 3,
  "name": "TIFF viewer",
  "description": "Open TIFF/TIF images in Chromium browsers with inline page rendering and a dedicated Manifest V3 viewer.",
  "version": "2.0.1",
  "homepage_url": "https://github.com/thanasis1885/tiff-viewer-extension",
  "minimum_chrome_version": "109",
  "incognito": "split",
  "author": "my codeworks",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "declarativeNetRequest",
    "offscreen",
    "storage",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/image-handler.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options/options.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "viewer/*",
        "icon16.png",
        "icon48.png",
        "icon128.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "128": "icon128.png",
    "48": "icon48.png",
    "16": "icon16.png"
  }
}
